
{
  "entities": {
    "DailyEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DailyEntry",
      "type": "object",
      "description": "Represents a single day's journal entry for a user, containing all content across the four dedicated pages.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Reference to the User who owns this daily entry."
        },
        "date": {
          "type": "string",
          "description": "The specific calendar date (YYYY-MM-DD).",
          "format": "date"
        },
        "checklist": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/ChecklistItem"
          }
        },
        "customChecklist": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/ChecklistItem"
          }
        },
        "reflectionPositive": {
          "type": "object",
          "properties": {
            "grateful": { "type": "string" },
            "learned": { "type": "string" }
          }
        },
        "reflectionGrowth": {
          "type": "object",
          "properties": {
            "drained": { "type": "string" },
            "improve": { "type": "string" }
          }
        },
        "mood": { "type": "string" },
        "freeWriting": { "type": "string" },
        "drawingData": { "type": "string" },
        "stickers": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Sticker"
          }
        },
        "rewardsClaimed": {
          "type": "object",
          "properties": {
            "habit50": { "type": "boolean" },
            "habit100": { "type": "boolean" },
            "journalAny": { "type": "boolean" },
            "journalAll": { "type": "boolean" }
          }
        }
      },
      "required": ["userId", "date"]
    },
    "ChecklistItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "checked": { "type": "boolean" }
      }
    },
    "Routine": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "RoutineList": {
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Routine"
          }
        }
      }
    },
    "Sticker": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "scale": { "type": "number" }
      }
    },
    "GoalList": {
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "goals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        }
      }
    },
    "UserStats": {
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "hearts": { "type": "number" },
        "stars": { "type": "number" },
        "petals": { "type": "number" },
        "badges": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}/dailyEntries/{dateId}": {
      "schema": "#/backend/entities/DailyEntry",
      "description": "User's daily journal entry for a specific date."
    },
    "/users/{userId}/monthlyGoals/{monthId}": {
      "schema": "#/backend/entities/GoalList",
      "description": "User's goals for a specific month (YYYY-MM)."
    },
    "/users/{userId}/yearlyGoals/{yearId}": {
      "schema": "#/backend/entities/GoalList",
      "description": "User's goals for a specific year (YYYY)."
    },
    "/users/{userId}/settings/routines": {
      "schema": "#/backend/entities/RoutineList",
      "description": "Global routine items that appear on all days."
    },
    "/users/{userId}/settings/stats": {
      "schema": "#/backend/entities/UserStats",
      "description": "Historical reward collection and badges for the user."
    }
  }
}
